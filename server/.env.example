# Shared API bind settings
HOST=0.0.0.0
PORT=8787

# Primary PostgreSQL connection string used by the shared API
DATABASE_URL=postgresql://postgres:password@localhost:5432/infolib

# Optional override used by some local desktop workflows
DEV_DATABASE_URL=

# Comma-separated browser origins allowed to call the API with credentials
# Add your Vercel web URL here when deploying the frontend separately.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
